# Use "local" for Ollama/OpenAI-compatible local inference, or "cloud" for Anthropic.
DIRECTOR_BACKEND=local

# Local Director model name. The Windows setup script creates this derived Ollama model.
LOCAL_DIRECTOR_MODEL=infiltration-director

# Local Ollama default. Use 127.0.0.1 to avoid localhost resolving to IPv6 on Windows.
OLLAMA_URL=http://127.0.0.1:11434/v1/chat/completions

# Cloud mode only.
# ANTHROPIC_API_KEY=sk-ant-...

# Admin cheat menu. Unlock in-game with `/admin <secret>`. Leave unset to make
# the cheat menu impossible to unlock. Set this in Railway, not just locally.
# ADMIN_SECRET=change-me-to-something-only-you-know
